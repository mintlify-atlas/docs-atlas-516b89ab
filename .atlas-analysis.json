  "publicApiSurface": [
    "GET /api/animals - List all animals",
    "GET /api/animals/{id} - Get animal by ID",
    "GET /api/habitats - List all habitats",
    "GET /api/habitats/{id} - Get habitat by ID",
    "GET /api/services - List all services",
    "GET /api/schedules - Get zoo schedules",
    "GET /api/testimonials - Get validated testimonials",
    "/auth/pages/login - User authentication",
    "/auth/pages/logout - User logout",
    "/home/pages/index - Public homepage",
    "/home/pages/start - Dashboard (authenticated)",
    "/animals/pages/allanimals - Browse animals",
    "/animals/pages/animalpicked - Animal details",
    "/animals/feeding/* - Feeding management (employee)",
    "/animals/gest/* - Animal CRUD (admin)",
    "/habitats/pages/* - Browse habitats",
    "/habitats/gest/* - Habitat CRUD (admin)",
    "/vreports/* - Veterinary reports",
    "/users/gest/* - User management (admin)",
    "/employees/gest/* - Employee management (admin)",
    "/roles/gest/* - Role management (admin)",
    "/permissions/gest/* - Permission management (admin)",
    "/testimonials/pages/* - Public testimonials",
    "/testimonials/gest/* - Testimonial moderation (employee)",
    "/contact/pages/form - Contact form"
  ]
